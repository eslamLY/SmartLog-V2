# ─── SMARTLOG — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control!

# Flask
FLASK_ENV=development
# FLASK_ENV=production
# PRODUCTION=true

# Secret Key (generate: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=ChangeMeToARandom64CharHexString!

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///smartlog.db
# DATABASE_URL=postgresql://user:password@host:5432/smartlog

# Field-level encryption key (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FIELD_ENCRYPTION_KEY=

# Backup encryption key (same Fernet format as FIELD_ENCRYPTION_KEY)
BACKUP_ENCRYPTION_KEY=

# Mail server (optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@smartlog.ly
