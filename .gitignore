# ─── Environment ────────────────────────────────────────────────────────────
.env
*.env.local
*.env.prod

# ─── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
*.so
*.dll
*.dylib

# ─── Virtualenv ──────────────────────────────────────────────────────────────
venv/
.venv/
env/
.venv/

# ─── IDE / Editor ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Logs & Temp ───────────────────────────────────────────────────────────
*.log
*.tmp
*.pid
instance/

# ─── Uploads (user-generated content) ─────────────────────────────────────
uploads/
backups/

# ─── Testing ───────────────────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
coverage.xml
*.cover

# ─── Database ──────────────────────────────────────────────────────────────
*.db
*.sqlite

# ─── Project-specific ──────────────────────────────────────────────────────
!.env.example
_temp/
scripts/*.json

# ─── Static files — DO NOT ignore these ──────────────────────────────────
# static/ is TRACKED — contains CSS, JS, icons, manifest, service worker
# To verify: git ls-files static/
# If static/ shows as deleted, run: git add -f static/
# This comment block prevents accidental .gitignore from hiding static/
